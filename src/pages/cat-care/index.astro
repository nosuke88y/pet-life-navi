---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('cat-care')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const tagCount = new Map<string, number>();
posts.forEach((p) => p.data.tags.forEach((t) => tagCount.set(t, (tagCount.get(t) || 0) + 1)));
const allTags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]).map(([tag]) => tag);
---

<BaseLayout title="猫のケア・グルーミング記事一覧" description="猫のシャンプー・耳掃除・爪切り・歯磨き・ブラッシングなどケアとグルーミングに関する記事をまとめています。">
  <div class="max-w-4xl mx-auto px-4 py-10">
    <div class="flex items-center gap-3 mb-6">
      <span class="text-4xl">✂️</span>
      <div>
        <h1 class="text-2xl font-bold text-gray-900">猫のケア・グルーミング</h1>
        <p class="text-sm text-gray-500 mt-0.5">全{posts.length}件</p>
      </div>
    </div>

    <div class="mb-8 flex flex-wrap gap-2" id="tag-filter">
      <button class="tag-btn active px-3 py-1.5 rounded-full text-sm font-medium border border-emerald-600 bg-emerald-600 text-white transition-colors" data-tag="all">すべて表示</button>
      {allTags.map((tag) => (
        <button class="tag-btn px-3 py-1.5 rounded-full text-sm font-medium border border-gray-300 text-gray-600 hover:border-emerald-400 hover:text-emerald-700 transition-colors" data-tag={tag}>#{tag}</button>
      ))}
    </div>

    {posts.length === 0 ? (
      <p class="text-gray-500 text-center py-20">記事はまだありません。</p>
    ) : (
      <div class="grid md:grid-cols-2 gap-4" id="article-grid">
        {posts.map((post) => (
          <ArticleCard title={post.data.title} description={post.data.description} date={post.data.date} tags={post.data.tags} href={`/cat-care/${post.id}/`} />
        ))}
      </div>
    )}
    <p id="no-results" class="text-gray-500 text-center py-10 hidden">該当する記事がありません。</p>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const cards = document.querySelectorAll<HTMLElement>('.article-card');
  const noResults = document.getElementById('no-results');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag;
      buttons.forEach((b) => { b.classList.remove('active','bg-emerald-600','text-white','border-emerald-600'); b.classList.add('border-gray-300','text-gray-600'); });
      btn.classList.add('active','bg-emerald-600','text-white','border-emerald-600'); btn.classList.remove('border-gray-300','text-gray-600');
      let v = 0;
      cards.forEach((c) => { const t = (c.dataset.tags||'').split(','); const s = tag==='all'||t.includes(tag!); c.style.display = s?'':'none'; if(s) v++; });
      if (noResults) noResults.classList.toggle('hidden', v > 0);
    });
  });
</script>
