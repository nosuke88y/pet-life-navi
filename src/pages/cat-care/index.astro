---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('cat-care')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const themes = [
  { label: 'すべて', key: 'all' },
  { label: 'シャンプー', key: 'shampoo' },
  { label: '爪切り・耳掃除', key: 'nailear' },
  { label: '歯磨き・デンタル', key: 'dental' },
  { label: 'ブラッシング', key: 'brushing' },
];

function getThemes(tags: string[]): string[] {
  const joined = tags.join(' ');
  const result: string[] = [];
  if (/シャンプー|長毛/.test(joined)) result.push('shampoo');
  if (/爪切り|耳掃除/.test(joined)) result.push('nailear');
  if (/歯磨き|デンタル|歯周病/.test(joined)) result.push('dental');
  if (/ブラッシング|毛玉対策|抜け毛/.test(joined)) result.push('brushing');
  return result;
}
---

<BaseLayout title="猫のケア・グルーミング記事一覧" description="猫のシャンプー・耳掃除・爪切り・歯磨き・ブラッシングなどケアとグルーミングに関する記事をまとめています。">
  <div class="max-w-4xl mx-auto px-4 py-10">
    <div class="flex items-center gap-3 mb-6">
      <span class="text-4xl">✂️</span>
      <div>
        <h1 class="text-2xl font-bold text-gray-900">猫のケア・グルーミング</h1>
        <p class="text-sm text-gray-500 mt-0.5">全{posts.length}件</p>
      </div>
    </div>

    <div class="mb-8 flex flex-wrap gap-2" id="theme-filter">
      {themes.map((theme, i) => (
        <button
          class={`theme-btn px-4 py-2 rounded-full text-sm font-medium border transition-colors ${
            i === 0
              ? 'active border-emerald-600 bg-emerald-600 text-white'
              : 'border-gray-300 text-gray-600 hover:border-emerald-400 hover:text-emerald-700'
          }`}
          data-theme={theme.key}
        >
          {theme.label}
        </button>
      ))}
    </div>

    {posts.length === 0 ? (
      <p class="text-gray-500 text-center py-20">記事はまだありません。</p>
    ) : (
      <div class="grid md:grid-cols-2 gap-4" id="article-grid">
        {posts.map((post) => {
          const articleThemes = getThemes(post.data.tags);
          return (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              tags={post.data.tags}
              href={`/cat-care/${post.id}/`}
              data-themes={articleThemes.join(',')}
            />
          );
        })}
      </div>
    )}
    <p id="no-results" class="text-gray-500 text-center py-10 hidden">該当する記事がありません。</p>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.theme-btn');
  const cards = document.querySelectorAll<HTMLElement>('.article-card');
  const noResults = document.getElementById('no-results');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const theme = btn.dataset.theme;
      buttons.forEach((b) => { b.classList.remove('active','bg-emerald-600','text-white','border-emerald-600'); b.classList.add('border-gray-300','text-gray-600'); });
      btn.classList.add('active','bg-emerald-600','text-white','border-emerald-600'); btn.classList.remove('border-gray-300','text-gray-600');
      let v = 0;
      cards.forEach((c) => { const t = (c.dataset.themes||'').split(','); const s = theme==='all'||t.includes(theme!); c.style.display = s?'':'none'; if(s) v++; });
      if (noResults) noResults.classList.toggle('hidden', v > 0);
    });
  });
</script>
