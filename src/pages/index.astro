---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const dogPosts = await getCollection('dog');
const catPosts = await getCollection('cat');
const dogCarePosts = await getCollection('dog-care');
const catCarePosts = await getCollection('cat-care');

const categoryMap = new Map<string, string>();
dogPosts.forEach(p => categoryMap.set(p.id, 'dog'));
catPosts.forEach(p => categoryMap.set(p.id, 'cat'));
dogCarePosts.forEach(p => categoryMap.set(p.id, 'dog-care'));
catCarePosts.forEach(p => categoryMap.set(p.id, 'cat-care'));

// おすすめ記事（手動指定）
const recommendedIds = [
  { collection: 'dog', id: 'dog-food-for-liver-disease' },
  { collection: 'dog', id: 'dog-food-for-kidney-disease' },
  { collection: 'dog', id: 'dog-food-for-skin-itching' },
  { collection: 'cat', id: 'cat-kidney-disease-diet-guide' },
  { collection: 'dog-care', id: 'dog-ear-cleaning-guide' },
  { collection: 'cat-care', id: 'kitten-shampoo-guide' },
];

const allPosts = [...dogPosts, ...catPosts, ...dogCarePosts, ...catCarePosts];
const recommendedPosts = recommendedIds
  .map(({ collection, id }) => {
    const post = allPosts.find((p) => p.id === id && categoryMap.get(p.id) === collection);
    return post ? { post, category: collection } : null;
  })
  .filter(Boolean) as { post: typeof allPosts[number]; category: string }[];

const categories = [
  {
    href: '/dog/',
    emoji: '🐶',
    label: '犬の記事',
    count: dogPosts.length,
    description: 'フード選び・病気ケア・アレルギー対策',
    gradient: 'from-[#2E7D32] to-[#43A047]',
  },
  {
    href: '/cat/',
    emoji: '🐱',
    label: '猫の記事',
    count: catPosts.length,
    description: 'フード選び・健康管理・年齢別ケア',
    gradient: 'from-[#388E3C] to-[#66BB6A]',
  },
  {
    href: '/dog-care/',
    emoji: '🐾',
    label: '犬のケア',
    count: dogCarePosts.length,
    description: 'シャンプー・爪切り・歯磨き・トリミング',
    gradient: 'from-[#00897B] to-[#26A69A]',
  },
  {
    href: '/cat-care/',
    emoji: '✂️',
    label: '猫のケア',
    count: catCarePosts.length,
    description: 'シャンプー・ブラッシング・爪切り・歯磨き',
    gradient: 'from-[#00897B] to-[#4DB6AC]',
  },
];
---

<BaseLayout title="Pet Life Navi">
  <!-- ヒーローセクション -->
  <section class="bg-gradient-to-br from-emerald-600 to-teal-700 text-white">
    <div class="max-w-4xl mx-auto px-4 py-16 text-center">
      <p class="text-emerald-200 text-sm font-medium mb-3 tracking-widest uppercase">ペット情報メディア</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-4 leading-tight">
        ペットともっと豊かに暮らすための<br class="hidden md:block">情報をお届けします
      </h1>
      <p class="text-emerald-100 text-base max-w-xl mx-auto">
        犬・猫の食事・健康・ケア・グルーミングに関する信頼できる情報を、わかりやすく解説します。
      </p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- カテゴリ選択 -->
    <section class="mb-14">
      <h2 class="text-lg font-bold text-gray-700 mb-5">カテゴリから探す</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {categories.map((cat) => (
          <a
            href={cat.href}
            class={`group rounded-2xl bg-gradient-to-br ${cat.gradient} p-6 md:p-8 text-white shadow-lg hover:shadow-2xl hover:scale-[1.03] transition-all duration-300`}
          >
            <!-- コンテンツ -->
            <div>
              <span class="text-4xl block mb-3">{cat.emoji}</span>
              <p class="text-xl font-bold mb-1">{cat.label}</p>
              <p class="text-sm text-white/80 mb-3">{cat.description}</p>
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium bg-white/20 px-3 py-1 rounded-full">
                  {cat.count}件の記事
                </span>
                <span class="text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">→ 見てみる</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- おすすめ記事 -->
    <section>
      <h2 class="text-lg font-bold text-gray-700 mb-5">おすすめ記事</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {recommendedPosts.map(({ post, category }) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            href={`/${category}/${post.id}/`}
          />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
