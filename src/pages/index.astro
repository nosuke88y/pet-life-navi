---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

// 全カテゴリの記事を取得して日付降順に並べる
const dogPosts = await getCollection('dog');
const catPosts = await getCollection('cat');
const dogCarePosts = await getCollection('dog-care');
const catCarePosts = await getCollection('cat-care');

// カテゴリ判定用マップ（id → category）
const categoryMap = new Map<string, string>();
dogPosts.forEach(p => categoryMap.set(p.id, 'dog'));
catPosts.forEach(p => categoryMap.set(p.id, 'cat'));
dogCarePosts.forEach(p => categoryMap.set(p.id, 'dog-care'));
catCarePosts.forEach(p => categoryMap.set(p.id, 'cat-care'));

const allPosts = [...dogPosts, ...catPosts, ...dogCarePosts, ...catCarePosts].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const recentPosts = allPosts.slice(0, 6);
---

<BaseLayout title="Pet Life Navi">
  <!-- ヒーローセクション -->
  <section class="bg-gradient-to-br from-emerald-600 to-teal-700 text-white">
    <div class="max-w-4xl mx-auto px-4 py-16 text-center">
      <p class="text-emerald-200 text-sm font-medium mb-3 tracking-widest uppercase">ペット情報メディア</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-4 leading-tight">
        ペットともっと豊かに暮らすための<br class="hidden md:block">情報をお届けします
      </h1>
      <p class="text-emerald-100 text-base max-w-xl mx-auto">
        犬・猫の食事・健康・ケア・グルーミングに関する信頼できる情報を、わかりやすく解説します。
      </p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- カテゴリ選択 -->
    <section class="mb-14">
      <h2 class="text-lg font-bold text-gray-700 mb-5">カテゴリから探す</h2>
      <div class="grid grid-cols-2 gap-4">
        <a
          href="/dog/"
          class="group bg-white border border-gray-200 rounded-2xl p-6 text-center hover:shadow-md hover:border-emerald-300 transition-all"
        >
          <div class="text-5xl mb-3">🐶</div>
          <p class="font-bold text-gray-800 group-hover:text-emerald-700 transition-colors">犬の記事</p>
          <p class="text-sm text-gray-500 mt-1">{dogPosts.length}件</p>
        </a>
        <a
          href="/cat/"
          class="group bg-white border border-gray-200 rounded-2xl p-6 text-center hover:shadow-md hover:border-emerald-300 transition-all"
        >
          <div class="text-5xl mb-3">🐱</div>
          <p class="font-bold text-gray-800 group-hover:text-emerald-700 transition-colors">猫の記事</p>
          <p class="text-sm text-gray-500 mt-1">{catPosts.length}件</p>
        </a>
        <a
          href="/dog-care/"
          class="group bg-white border border-gray-200 rounded-2xl p-6 text-center hover:shadow-md hover:border-emerald-300 transition-all"
        >
          <div class="text-5xl mb-3">🐾</div>
          <p class="font-bold text-gray-800 group-hover:text-emerald-700 transition-colors">犬のケア</p>
          <p class="text-sm text-gray-500 mt-1">{dogCarePosts.length}件</p>
        </a>
        <a
          href="/cat-care/"
          class="group bg-white border border-gray-200 rounded-2xl p-6 text-center hover:shadow-md hover:border-emerald-300 transition-all"
        >
          <div class="text-5xl mb-3">✂️</div>
          <p class="font-bold text-gray-800 group-hover:text-emerald-700 transition-colors">猫のケア</p>
          <p class="text-sm text-gray-500 mt-1">{catCarePosts.length}件</p>
        </a>
      </div>
    </section>

    <!-- 新着記事 -->
    <section>
      <h2 class="text-lg font-bold text-gray-700 mb-5">新着記事</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {recentPosts.map((post) => {
          const category = categoryMap.get(post.id) ?? 'dog';
          return (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              tags={post.data.tags}
              href={`/${category}/${post.id}/`}
            />
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>
