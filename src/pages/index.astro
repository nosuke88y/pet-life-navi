---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { ChevronRight } from 'lucide-astro';
import { getCollection } from 'astro:content';

const dogPosts = await getCollection('dog');
const catPosts = await getCollection('cat');
const dogCarePosts = await getCollection('dog-care');
const catCarePosts = await getCollection('cat-care');

const categoryMap = new Map<string, string>();
dogPosts.forEach(p => categoryMap.set(p.id, 'dog'));
catPosts.forEach(p => categoryMap.set(p.id, 'cat'));
dogCarePosts.forEach(p => categoryMap.set(p.id, 'dog-care'));
catCarePosts.forEach(p => categoryMap.set(p.id, 'cat-care'));

// おすすめ記事（手動指定）
const recommendedIds = [
  { collection: 'dog', id: 'dog-food-for-liver-disease' },
  { collection: 'dog', id: 'dog-food-for-kidney-disease' },
  { collection: 'dog', id: 'dog-food-for-skin-itching' },
  { collection: 'cat', id: 'cat-kidney-disease-diet-guide' },
  { collection: 'dog-care', id: 'dog-ear-cleaning-guide' },
  { collection: 'cat-care', id: 'kitten-shampoo-guide' },
];

const allPosts = [...dogPosts, ...catPosts, ...dogCarePosts, ...catCarePosts];
const recommendedPosts = recommendedIds
  .map(({ collection, id }) => {
    const post = allPosts.find((p) => p.id === id && categoryMap.get(p.id) === collection);
    return post ? { post, category: collection } : null;
  })
  .filter(Boolean) as { post: typeof allPosts[number]; category: string }[];

const categories = [
  { href: '/dog/', label: '犬の記事', count: dogPosts.length, description: 'フード選び・病気ケア・アレルギー対策' },
  { href: '/cat/', label: '猫の記事', count: catPosts.length, description: 'フード選び・健康管理・年齢別ケア' },
  { href: '/dog-care/', label: '犬のケア', count: dogCarePosts.length, description: 'シャンプー・爪切り・歯磨き・トリミング' },
  { href: '/cat-care/', label: '猫のケア', count: catCarePosts.length, description: 'シャンプー・ブラッシング・爪切り・歯磨き' },
];

const siteUrl = 'https://pet-life-navi.com';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Pet Life Navi',
  alternateName: 'ペットライフナビ',
  url: `${siteUrl}/`,
  inLanguage: 'ja',
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Pet Life Navi',
  url: `${siteUrl}/`,
  logo: `${siteUrl}/favicon.ico`,
  sameAs: ['https://x.com/pet_navi_jp'],
};

const jsonLd = [websiteSchema, organizationSchema];
---

<BaseLayout title="Pet Life Navi" jsonLd={jsonLd}>
  <!-- ヒーロー -->
  <section class="max-w-3xl mx-auto px-4 pt-16 pb-12 border-b border-[var(--color-rule)]">
    <p class="text-xs text-[var(--color-ink-mute)] tracking-[0.3em] uppercase mb-5">Pet Information</p>
    <h1 class="text-3xl md:text-4xl font-medium text-[var(--color-ink)] leading-tight tracking-tight mb-5">
      ペットともっと豊かに暮らすための情報を。
    </h1>
    <p class="text-sm md:text-base text-[var(--color-ink-sub)] leading-relaxed max-w-xl">
      犬・猫の食事・健康・ケア・グルーミングに関する信頼できる情報を、わかりやすく解説します。
    </p>
  </section>

  <div class="max-w-3xl mx-auto px-4 py-12">
    <!-- カテゴリ -->
    <section class="mb-16">
      <h2 class="text-xs text-[var(--color-ink-mute)] tracking-widest uppercase mb-4">Categories</h2>
      <ul class="border-t border-[var(--color-rule)]">
        {categories.map((cat) => (
          <li>
            <a href={cat.href} class="group flex items-center justify-between gap-4 py-5 border-b border-[var(--color-rule)] transition-colors hover:bg-neutral-100 px-3 -mx-3">
              <div class="min-w-0 flex-1">
                <p class="text-base font-medium text-[var(--color-accent-700)] underline underline-offset-4 decoration-[var(--color-accent-600)]/40 group-hover:decoration-[var(--color-accent-600)]">{cat.label}</p>
                <p class="text-sm text-[var(--color-ink-mute)] mt-1">{cat.description}</p>
              </div>
              <span class="shrink-0 text-2xl font-medium text-[var(--color-accent-700)] tabular-nums">{cat.count}</span>
              <ChevronRight size={18} strokeWidth={1.5} class="shrink-0 text-[var(--color-ink-mute)] group-hover:text-[var(--color-accent-700)] group-hover:translate-x-0.5 transition-all" />
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- おすすめ記事 -->
    <section>
      <h2 class="text-xs text-[var(--color-ink-mute)] tracking-widest uppercase mb-4">Featured</h2>
      <div class="border-t border-[var(--color-rule)]">
        {recommendedPosts.map(({ post, category }) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            href={`/${category}/${post.id}/`}
          />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
