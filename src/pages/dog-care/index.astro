---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('dog-care')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const themes = [
  { label: 'すべて', key: 'all' },
  { label: 'シャンプー', key: 'shampoo' },
  { label: '爪切り・耳掃除', key: 'nailear' },
  { label: '歯磨き・デンタル', key: 'dental' },
  { label: 'トリミング', key: 'trimming' },
];

function getThemes(tags: string[]): string[] {
  const joined = tags.join(' ');
  const result: string[] = [];
  if (/シャンプー|お湯/.test(joined)) result.push('shampoo');
  if (/爪切り|耳掃除/.test(joined)) result.push('nailear');
  if (/歯磨き|デンタル|口腔/.test(joined)) result.push('dental');
  if (/トリミング|サロン/.test(joined)) result.push('trimming');
  return result;
}
---

<BaseLayout title="犬のケア・グルーミング記事一覧" description="犬のシャンプー・耳掃除・爪切り・歯磨きなどケアとグルーミングに関する記事をまとめています。">
  <div class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-8 pb-6 border-b border-[var(--color-rule)]">
      <h1 class="text-2xl md:text-3xl font-medium text-[var(--color-ink)] tracking-tight">犬のケア・グルーミング</h1>
      <p class="text-sm text-[var(--color-ink-mute)] mt-2 tabular-nums">全{posts.length}件</p>
    </header>

    <div class="mb-4 flex flex-wrap gap-x-5 gap-y-2" id="theme-filter">
      {themes.map((theme, i) => (
        <button
          class={`theme-btn text-sm transition-colors ${
            i === 0
              ? 'active text-[var(--color-accent-700)] font-medium'
              : 'text-[var(--color-ink-mute)] hover:text-[var(--color-ink)]'
          }`}
          data-theme={theme.key}
        >
          {theme.label}
        </button>
      ))}
    </div>

    {posts.length === 0 ? (
      <p class="text-[var(--color-ink-mute)] text-center py-20">記事はまだありません。</p>
    ) : (
      <div class="border-t border-[var(--color-rule)]" id="article-grid">
        {posts.map((post) => {
          const articleThemes = getThemes(post.data.tags);
          return (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              tags={post.data.tags}
              href={`/dog-care/${post.id}/`}
              data-themes={articleThemes.join(',')}
            />
          );
        })}
      </div>
    )}
    <p id="no-results" class="text-[var(--color-ink-mute)] text-center py-10 hidden">該当する記事がありません。</p>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.theme-btn');
  const cards = document.querySelectorAll<HTMLElement>('.article-card');
  const noResults = document.getElementById('no-results');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const theme = btn.dataset.theme;
      buttons.forEach((b) => { b.classList.remove('active','text-[var(--color-accent-700)]','font-medium'); b.classList.add('text-[var(--color-ink-mute)]'); });
      btn.classList.add('active','text-[var(--color-accent-700)]','font-medium'); btn.classList.remove('text-[var(--color-ink-mute)]');
      let v = 0;
      cards.forEach((c) => { const t = (c.dataset.themes||'').split(','); const s = theme==='all'||t.includes(theme!); c.style.display = s?'':'none'; if(s) v++; });
      if (noResults) noResults.classList.toggle('hidden', v > 0);
    });
  });
</script>
