---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import { extractFaq } from '../../utils/extractFaq';

export async function getStaticPaths() {
  const posts = await getCollection('dog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

// 関連記事：同カテゴリから現在の記事を除き、ランダムで3本取得
const otherPosts = allPosts.filter((p) => p.id !== post.id);
const shuffled = otherPosts.sort(() => Math.random() - 0.5);
const relatedPosts = shuffled.slice(0, 3).map((p) => ({
  title: p.data.title,
  description: p.data.description,
  date: p.data.date,
  tags: p.data.tags,
  href: `/dog/${p.id}/`,
}));

const faqItems = extractFaq(post.body ?? '');
---

<ArticleLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  tags={post.data.tags}
  category="dog"
  headings={headings}
  relatedPosts={relatedPosts}
  faqItems={faqItems}
>
  <Content />
</ArticleLayout>
