---

<div class="affiliate-box">
  <p class="affiliate-title">🐾 おすすめ商品</p>
  {links.map(link => (
    <div class="affiliate-item">
      <a href={link.href} rel="nofollow">{link.text}</a>
      <img border="0" width="1" height="1" src={link.img} alt="" />
    </div>
  ))}
</div>

<style>
  .affiliate-box {
    background: #f8f8f8;
    border: 1px solid #ddd;
    padding: 12px;
    margin: 16px 0;
    border-radius: 6px;
  }
  .affiliate-title {
    font-weight: bold;
    margin: 0 0 8px 0;
    padding: 0;
  }
  .affiliate-item {
    margin: 0;
    padding: 2px 0;
    line-height: 1.5;
  }
</style>
