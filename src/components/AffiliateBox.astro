---

<aside class="affiliate-box not-prose">
  <p class="affiliate-label">おすすめアイテム</p>
  <ul class="affiliate-list">
    {links.map(link => (
      <li class="affiliate-item">
        <a href={link.href} rel="nofollow sponsored">{link.text}</a>
        <img border="0" width="1" height="1" src={link.img} alt="" />
      </li>
    ))}
  </ul>
</aside>

<style>
  .affiliate-box {
    border: 1px solid var(--color-rule);
    padding: 1.25rem 1.25rem 0.75rem;
    margin: 2rem 0;
    background: transparent;
  }
  .affiliate-label {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-mute);
    font-weight: 500;
    margin: 0 0 0.75rem 0;
  }
  .affiliate-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .affiliate-item {
    padding: 0.625rem 0;
    border-top: 1px solid var(--color-rule);
    line-height: 1.6;
    font-size: 0.875rem;
  }
  .affiliate-item:first-child {
    border-top: none;
    padding-top: 0;
  }
  .affiliate-item a {
    color: var(--color-ink);
    text-decoration: none;
    transition: color 0.15s;
  }
  .affiliate-item a:hover {
    color: var(--color-accent-700);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
