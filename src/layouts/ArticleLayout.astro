---
import BaseLayout from './BaseLayout.astro';
import AffiliateBox from '../components/AffiliateBox.astro';

interface AffiliateLink {
  label: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  affiliateLinks?: AffiliateLink[];
  category: 'dog' | 'cat';
}

const { title, description, date, tags, affiliateLinks = [], category } = Astro.props;

const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryLabel = category === 'dog' ? '🐶 犬' : '🐱 猫';
const categoryHref = `/${category}/`;
---

<BaseLayout title={title} description={description}>
  <div class="max-w-3xl mx-auto px-4 py-10">

    <!-- パンくずリスト -->
    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
      <a href="/" class="hover:text-emerald-600 transition-colors">ホーム</a>
      <span>/</span>
      <a href={categoryHref} class="hover:text-emerald-600 transition-colors">{categoryLabel}</a>
      <span>/</span>
      <span class="text-gray-600 truncate">{title}</span>
    </nav>

    <!-- タグ -->
    <div class="flex flex-wrap gap-1 mb-4">
      {tags.map((tag) => (
        <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">
          #{tag}
        </span>
      ))}
    </div>

    <!-- 記事タイトル -->
    <h1 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight mb-3">
      {title}
    </h1>

    <!-- 投稿日 -->
    <time datetime={date.toISOString()} class="text-sm text-gray-400 block mb-8">
      {formattedDate}
    </time>

    <!-- アフィリエイトボックス（本文前） -->
    {affiliateLinks.length > 0 && <AffiliateBox links={affiliateLinks} />}

    <!-- 記事本文 -->
    <article class="
      prose prose-gray max-w-none
      prose-base leading-relaxed
      prose-p:text-gray-700 prose-p:leading-[1.9] prose-p:mb-6
      prose-h2:text-2xl prose-h2:font-bold prose-h2:text-gray-900
        prose-h2:mt-12 prose-h2:mb-5 prose-h2:pb-2
        prose-h2:border-b-2 prose-h2:border-emerald-200
      prose-h3:text-xl prose-h3:font-bold prose-h3:text-gray-800
        prose-h3:mt-8 prose-h3:mb-3
      prose-ul:my-5 prose-ul:pl-2
      prose-ol:my-5 prose-ol:pl-2
      prose-li:text-gray-700 prose-li:leading-[1.8] prose-li:my-1
      prose-table:text-sm prose-th:bg-gray-100 prose-th:text-gray-700
        prose-td:text-gray-600
      prose-strong:text-gray-900 prose-strong:font-bold
      prose-a:text-emerald-700 prose-a:underline prose-a:underline-offset-2
    ">
      <slot />
    </article>

    <!-- アフィリエイトボックス（本文後） -->
    {affiliateLinks.length > 0 && <AffiliateBox links={affiliateLinks} />}

    <!-- カテゴリへ戻る -->
    <div class="mt-12 pt-8 border-t border-gray-200">
      <a
        href={categoryHref}
        class="inline-flex items-center gap-2 text-sm text-emerald-700 hover:text-emerald-600 font-medium transition-colors"
      >
        ← {categoryLabel}の記事一覧に戻る
      </a>
    </div>
  </div>
</BaseLayout>
