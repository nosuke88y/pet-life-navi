---
import BaseLayout from './BaseLayout.astro';
import AffiliateBox from '../components/AffiliateBox.astro';

interface AffiliateLink {
  label: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  affiliateLinks?: AffiliateLink[];
  category: 'dog' | 'cat';
}

const { title, description, date, tags, affiliateLinks = [], category } = Astro.props;

const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryLabel = category === 'dog' ? '🐶 犬' : '🐱 猫';
const categoryHref = `/${category}/`;
---

<BaseLayout title={title} description={description}>
  <div class="max-w-3xl mx-auto px-4 py-10">

    <!-- パンくずリスト -->
    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-1">
      <a href="/" class="hover:text-emerald-600 transition-colors">ホーム</a>
      <span>/</span>
      <a href={categoryHref} class="hover:text-emerald-600 transition-colors">{categoryLabel}</a>
      <span>/</span>
      <span class="text-gray-600 truncate">{title}</span>
    </nav>

    <!-- タグ -->
    <div class="flex flex-wrap gap-1 mb-4">
      {tags.map((tag) => (
        <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">
          #{tag}
        </span>
      ))}
    </div>

    <!-- 記事タイトル -->
    <h1 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight mb-3">
      {title}
    </h1>

    <!-- 投稿日 -->
    <time datetime={date.toISOString()} class="text-sm text-gray-400 block mb-8">
      {formattedDate}
    </time>

    <!-- アフィリエイトボックス（本文前） -->
    {affiliateLinks.length > 0 && <AffiliateBox links={affiliateLinks} />}

    <!-- 記事本文 -->
    <article class="prose prose-gray prose-headings:font-bold prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4 prose-h3:text-lg prose-h3:mt-6 prose-p:leading-relaxed prose-li:leading-relaxed max-w-none">
      <slot />
    </article>

    <!-- アフィリエイトボックス（本文後） -->
    {affiliateLinks.length > 0 && <AffiliateBox links={affiliateLinks} />}

    <!-- カテゴリへ戻る -->
    <div class="mt-12 pt-8 border-t border-gray-200">
      <a
        href={categoryHref}
        class="inline-flex items-center gap-2 text-sm text-emerald-700 hover:text-emerald-600 font-medium transition-colors"
      >
        ← {categoryLabel}の記事一覧に戻る
      </a>
    </div>
  </div>
</BaseLayout>
